{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": ".",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:prod": "cross-env NODE_ENV=production tsc -b && vite build --mode production",
    "build:analyze": "npm run build:prod && npx vite-bundle-analyzer dist/stats.html",
    "build:size": "npm run build:prod && npx bundlesize",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "preview:prod": "vite preview --mode production",
    "pre-deploy": "npm run lint && npm run build:prod && npm run check-env",
    "check-env": "node scripts/check-env.js",
    "deploy:prepare": "npm run pre-deploy && node scripts/prepare-deploy.js",
    "deploy:aws": "npm run deploy:prepare && node scripts/deploy-aws.js",
    "deploy:dry-run": "npm run deploy:prepare && node scripts/deploy-aws.js -- --dry-run",
    "clean": "rimraf dist",
    "type-check": "tsc --noEmit",
    "s3:setup": "node scripts/setup-s3.js",
    "s3:test": "node scripts/test-s3.js"
  },
  "dependencies": {
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.553.0",
    "nodemailer": "^7.0.11",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/node": "^24.10.0",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "bundlesize": "^0.18.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "rimraf": "^6.0.1",
    "rollup-plugin-visualizer": "^5.12.0",
    "sass": "^1.93.3",
    "terser": "^5.36.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vite-bundle-analyzer": "^0.11.0"
  }
}
